# ============================================================
# Matrix E2EE Bot — Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Matrix credentials
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_USER=@bot:example.com

# Use either password OR access token (not both)
MATRIX_PASSWORD=changeme
# MATRIX_ACCESS_TOKEN=your_access_token_here

# Bot identity
BOT_DISPLAY_NAME=Matrix Bot
# BOT_DEVICE_ID=MY_BOT_DEVICE  # optional: fix device ID for stable verification

# API security — generate with: openssl rand -hex 32
API_BEARER_TOKEN=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET

# Storage (inside container, backed by Docker volume)
CRYPTO_STORE_PATH=/app/data/crypto_store
SESSION_STORE_PATH=/app/data/sessions.db

# Runtime
LOG_LEVEL=INFO
SYNC_INTERVAL=30
